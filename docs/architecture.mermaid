%% Loop — Container diagram (C4 level 2). All lines = synchronous calls.
flowchart TD
    physician(["Physician<br/>[Person]"])

    subgraph LOCAL["Loop — runs locally on the clinic machine · no PHI leaves · synthetic data only"]
        direction TB
        ui["Web UI<br/>single-page, served by the API"]
        api["API<br/>FastAPI"]
        scanner["Scanner / Service<br/>orchestration"]
        fclient["FHIR client<br/>httpx (FHIR R4 REST)"]
        store[("Snapshot store<br/>SQLite")]
        diff["Diff engine<br/>content-hash + field-level diff"]
        summ["Safe summarizer<br/>+ safety post-filter"]
        llm["Local LLM<br/>Ollama · optional"]
    end

    fhir[["FHIR R4 source<br/>public HAPI / Synthea to local HAPI"]]

    subgraph FORK["Tomorrow's fork — UI mode on the same backend"]
        direction LR
        branchA["Branch A · Patient Context Board<br/>'what changed' / pre-visit prep"]
        branchB["Branch B · Form + necessity-gate<br/>+ saved-minutes"]
    end

    physician -->|"views board, approves items (HTTPS)"| ui
    ui -->|"REST / JSON"| api
    api -->|"scan / diff / context"| scanner
    scanner -->|"pull patients and resources (FHIR REST)"| fclient
    fclient -->|"GET Patient, Condition, Observation, ... (FHIR R4)"| fhir
    scanner -->|"save and load snapshots (SQL)"| store
    scanner -->|"classify changes"| diff
    diff -->|"structured diffs"| summ
    summ -->|"restate facts only — optional, local inference"| llm
    summ -->|"neutral, source-backed board"| api
    api --> branchA
    api --> branchB

    subgraph KEY["Key"]
        direction LR
        k1["Container / component = rectangle"]
        k2[("Database = cylinder")]
        k3[["External system = subroutine box"]]
        k4(["Person = stadium"])
    end

    classDef local fill:#E5F4EE,stroke:#0E8A6B,color:#10302a;
    classDef ext fill:#FBF1DC,stroke:#9A6B14,color:#3a2b0c;
    classDef db fill:#EEF1F4,stroke:#5A6675,color:#1A2330;
    classDef person fill:#FFFFFF,stroke:#1A2330,color:#1A2330;
    classDef branch fill:#FFFFFF,stroke:#0E8A6B,stroke-dasharray:4 3,color:#10302a;

    class ui,api,scanner,fclient,diff,summ,llm local;
    class store db;
    class fhir ext;
    class physician person;
    class branchA,branchB branch;
